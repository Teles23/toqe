{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-1234-567890abcdef",
    "name": "Toqe API v1",
    "description": "Collection completa para testar os endpoints da API Toqe.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Autenticação",
      "item": [
        {
          "name": "Registrar Usuário",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Admin Teste\",\n  \"email\": \"admin@toqe.com.br\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"access_token\", jsonData.access_token);",
                  "pm.environment.set(\"refresh_token\", jsonData.refresh_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@toqe.com.br\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Barbearia (Tenant)",
      "item": [
        {
          "name": "Criar Barbearia",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"tenant_id\", jsonData.codigo);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Barbearia Teste\",\n  \"slug\": \"barbearia-teste\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/barbearias",
              "host": ["{{baseUrl}}"],
              "path": ["barbearias"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Serviços",
      "item": [
        {
          "name": "Criar Serviço",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "x-tenant-id", "value": "{{tenant_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Corte de Cabelo\",\n  \"precoBase\": 45.00,\n  \"duracaoBase\": 30\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/servicos",
              "host": ["{{baseUrl}}"],
              "path": ["servicos"]
            }
          }
        },
        {
          "name": "Listar Serviços",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "x-tenant-id", "value": "{{tenant_id}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/servicos",
              "host": ["{{baseUrl}}"],
              "path": ["servicos"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Agenda",
      "item": [
        {
          "name": "Configurar Jornada (Segunda-feira)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "x-tenant-id", "value": "{{tenant_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"diaSemana\": 1,\n  \"inicio\": \"09:00\",\n  \"fim\": \"18:00\",\n  \"almocoIni\": \"12:00\",\n  \"almocoFim\": \"13:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/agenda/jornada/1",
              "host": ["{{baseUrl}}"],
              "path": ["agenda", "jornada", "1"]
            }
          }
        },
        {
          "name": "Consultar Disponibilidade",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "x-tenant-id", "value": "{{tenant_id}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/agenda/disponibilidade/1?data=2026-05-10&duracao=30",
              "host": ["{{baseUrl}}"],
              "path": ["agenda", "disponibilidade", "1"],
              "query": [
                { "key": "data", "value": "2026-05-10" },
                { "key": "duracao", "value": "30" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "5. Agendamentos",
      "item": [
        {
          "name": "Criar Agendamento",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "x-tenant-id", "value": "{{tenant_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"barbeiroId\": 1,\n  \"clienteId\": 1,\n  \"inicio\": \"2026-05-10T09:00:00.000Z\",\n  \"servicosIds\": [1]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/agendamentos",
              "host": ["{{baseUrl}}"],
              "path": ["agendamentos"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1"
    }
  ]
}
