# ============================================================
# Toqe — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Banco de dados ---
POSTGRES_USER=toqe_app
POSTGRES_PASSWORD=senha_forte
DATABASE_URL=postgresql://toqe_app:senha_forte@postgres:5432/toqe

# --- Redis ---
REDIS_PASSWORD=senha_forte
# REDIS_HOST e REDIS_PORT são fixos no compose (host=redis, port=6379)

# --- Autenticação ---
JWT_SECRET=troque_por_um_segredo_forte
JWT_REFRESH_SECRET=troque_por_outro_segredo_forte

# --- E-mail (Resend) ---
# Obtenha em https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Observabilidade ---
# DSN do projeto no Sentry (https://sentry.io) — deixe vazio para desativar
SENTRY_DSN=
# Nível de log: trace | debug | info | warn | error (padrão: info)
LOG_LEVEL=info

# --- Web (Next.js) ---
NEXTAUTH_SECRET=troque_por_um_segredo_forte
