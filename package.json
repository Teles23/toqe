{
  "name": "toqe",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "start:prod:api": "pnpm --filter api run start:prod",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "branding:generate": "node tools/branding/generate.mjs",
    "branding:check": "node tools/branding/generate.mjs --dry-run"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.7.4",
    "sharp": "^0.34.5",
    "turbo": "^2.9.9",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{md,json,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2",
      "fast-uri": ">=3.1.2",
      "flatted": ">=3.4.2",
      "glob>minimatch": ">=3.1.3",
      "@expo/cli>minimatch": ">=9.0.7",
      "test-exclude>minimatch": ">=3.1.3",
      "picomatch": ">=2.3.2",
      "@xmldom/xmldom": ">=0.8.13",
      "js-yaml": ">=4.1.1",
      "postcss": ">=8.5.10",
      "@hono/node-server": ">=1.19.13",
      "hono": ">=4.12.18"
    }
  }
}
