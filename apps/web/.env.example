# ==========================================
# WEB (Next.js)
# Ambiente de Desenvolvimento Local
# ==========================================

# ── URLs ───────────────────────────────────────────────────────────────────────

# URL pública da API NestJS — usada pelo browser e pelos componentes client-side.
# DEV:  http://localhost:3000/api/v1  (ou http://SEU_IP:3000/api/v1 em WSL2)
# PROD: https://api.toqe.com.br/api/v1
# OBRIGATÓRIO
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# URL interna da API NestJS usada pelos BFF route handlers (server-side, sem passar pelo browser).
# Em produção aponta para o container NestJS via rede privada (ex: http://api:3000/api/v1).
# Em dev, se omitido, usa NEXT_PUBLIC_API_URL como fallback automaticamente.
# OBRIGATÓRIO em produção
INTERNAL_API_URL=http://api:3000/api/v1

# ── Google OAuth ───────────────────────────────────────────────────────────────

# Client ID do Google OAuth — habilita o botão "Entrar com Google" na tela de login.
# Obtenha em: https://console.cloud.google.com/ → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web)
# Authorized JavaScript origins: http://localhost:3001 (dev) / https://app.toqe.com.br (prod)
# Se omitido, o botão Google fica oculto (funciona sem esta variável).
# opcional
NEXT_PUBLIC_GOOGLE_CLIENT_ID=seu-client-id-aqui.apps.googleusercontent.com

# ── Ambiente ───────────────────────────────────────────────────────────────────

# Identifica o ambiente de execução do frontend.
# Valores válidos: development | staging | production
# Usado no Sentry e em logs para filtrar eventos por ambiente.
# opcional (padrão: development)
NEXT_PUBLIC_APP_ENV=development

# ── Observabilidade ────────────────────────────────────────────────────────────

# DSN do projeto Sentry para captura de erros no frontend (browser + SSR).
# Obtenha em: https://sentry.io → seu projeto → Settings → Client Keys (DSN)
# Se omitido, o SDK do Sentry é desativado (sem erros, sem ruído).
# opcional
NEXT_PUBLIC_SENTRY_DSN=

# Token de autenticação do Sentry CLI — usado apenas em CI para upload de source maps.
# Obtenha em: https://sentry.io → User Settings → Auth Tokens
# Necessário apenas quando NEXT_PUBLIC_SENTRY_DSN estiver configurado e quiser
# mapear stack traces de produção para o código-fonte original.
# opcional (apenas CI/CD)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=sua-org-no-sentry
SENTRY_PROJECT=toqe-web

# ── Ferramentas de desenvolvimento ────────────────────────────────────────────

# Ativa o Bundle Analyzer do Next.js ao rodar `next build`.
# Use ANALYZE=true para gerar o relatório de tamanho de bundle.
# opcional (padrão: false)
ANALYZE=false

# URL base usada pelo Playwright nos testes E2E.
# Sobrescreva em CI para apontar para o ambiente de staging/preview.
# opcional (padrão: http://localhost:3001)
PLAYWRIGHT_BASE_URL=http://localhost:3001
