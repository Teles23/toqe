generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. USUÁRIOS E AUTENTICAÇÃO (GLOBAL)
// ==========================================

model Usuario {
  codigo    Int      @id @default(autoincrement()) @map("TQE_USR_CODIGO")
  nome      String   @map("TQE_USR_NOME") @db.VarChar(100)
  email     String   @unique @map("TQE_USR_EMAIL") @db.VarChar(100)
  // Nullable para suportar usuários OAuth (Google) que não têm senha local.
  // AuthService.login deve checar `!user.senhaHash` antes de bcrypt.compare.
  senhaHash String?  @map("TQE_USR_SENHA_HASH") @db.VarChar(255)
  telefone  String?  @unique @map("TQE_USR_TELEFONE") @db.VarChar(20)
  avatarUrl String?  @map("TQE_USR_AVATAR_URL")
  ativo        Boolean  @default(true) @map("TQE_USR_ATIVO")
  twoFaSecret  String?  @map("TQE_USR_TWO_FA_SECRET") @db.VarChar(64)
  twoFaEnabled Boolean  @default(false) @map("TQE_USR_TWO_FA_ENABLED")
  // Acesso irrestrito ao painel Super Admin (fundador). Setado via SUPER_ADMIN_EMAIL env.
  superAdmin      Boolean   @default(false) @map("TQE_USR_SUPER_ADMIN")
  dataNascimento  DateTime? @map("TQE_USR_DATA_NASCIMENTO") @db.Date
  criadoEm  DateTime @default(now()) @map("TQE_USR_CRIADO_EM") @db.Timestamptz

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  membros        MembroBarbearia[]
  agendamentos   Agendamento[]      @relation("AgendamentosCliente")
  atendimentos   Agendamento[]      @relation("AgendamentosBarbeiro")
  bloqueios      BloqueioAgenda[]
  jornadas       JornadaTrabalho[]
  servicosProps  BarbeiroServico[]
  servicosExcl   Servico[]          @relation("ServicoExclusivo")
  preferencias   NotificacaoPreferencia[]
  pushTokens     PushToken[]
  notasFeitas    ClienteNota[]      @relation("NotaBarbeiro")
  notasRecebidas ClienteNota[]      @relation("NotaCliente")
  pontosFidelidade PontoFidelidade[]
  pontosAcumulados Int              @default(0) @map("TQE_USR_PONTOS_ACUMULADOS")

  @@map("TQE_USUARIO")
}

model RefreshToken {
  codigo    Int      @id @default(autoincrement()) @map("TQE_RTK_CODIGO")
  usrCodigo Int      @map("TQE_RTK_USR_CODIGO")
  hash      String   @map("TQE_RTK_HASH") @db.VarChar(255)
  expiraEm  DateTime @map("TQE_RTK_EXPIRA_EM") @db.Timestamptz
  revogado  Boolean  @default(false) @map("TQE_RTK_REVOGADO")
  criadoEm  DateTime @default(now()) @map("TQE_RTK_CRIADO_EM") @db.Timestamptz

  usuario   Usuario  @relation(fields: [usrCodigo], references: [codigo])

  @@map("TQE_REFRESH_TOKEN")
}

model PasswordResetToken {
  codigo    Int       @id @default(autoincrement()) @map("TQE_PRT_CODIGO")
  usrCodigo Int       @map("TQE_PRT_USR_CODIGO")
  token     String    @unique @map("TQE_PRT_TOKEN") @db.VarChar(100)
  expiraEm  DateTime  @map("TQE_PRT_EXPIRA_EM") @db.Timestamptz
  usadoEm   DateTime? @map("TQE_PRT_USADO_EM") @db.Timestamptz
  criadoEm  DateTime  @default(now()) @map("TQE_PRT_CRIADO_EM") @db.Timestamptz

  usuario   Usuario   @relation(fields: [usrCodigo], references: [codigo])

  @@map("TQE_PASSWORD_RESET_TOKEN")
}

// ==========================================
// 2. TENANTS E CONFIGURAÇÕES
// ==========================================

model Barbearia {
  codigo      Int      @id @default(autoincrement()) @map("TQE_BAR_CODIGO")
  nome        String   @map("TQE_BAR_NOME") @db.VarChar(100)
  slug        String   @unique @map("TQE_BAR_SLUG") @db.VarChar(60)
  timezone    String   @default("America/Sao_Paulo") @map("TQE_BAR_TIMEZONE")
  slotInterval Int      @default(30) @map("TQE_BAR_SLOT_INTERVAL")
  plano       String   @default("free") @map("TQE_BAR_PLANO") // free | basic | pro
  planoStatus String   @default("trial") @map("TQE_BAR_PLANO_STATUS") // trial | ativo | inadimplente | suspenso | cancelado
  trialFim    DateTime? @map("TQE_BAR_TRIAL_FIM") @db.Timestamptz
  planoValidoAte DateTime? @map("TQE_BAR_PLANO_VALIDO_ATE") @db.Timestamptz
  asaasCustomerId     String? @map("TQE_BAR_ASAAS_CUSTOMER_ID") @db.VarChar(50)
  asaasSubscriptionId String? @map("TQE_BAR_ASAAS_SUBSCRIPTION_ID") @db.VarChar(50)
  bloqueadaEm DateTime? @map("TQE_BAR_BLOQUEADA_EM") @db.Timestamptz
  ativo       Boolean  @default(true) @map("TQE_BAR_ATIVO")
  // Permissões que o dono concede aos barbeiros sobre serviços
  barbeiroCriaServico Boolean @default(false) @map("TQE_BAR_BARBEIRO_CRIA_SERVICO")
  barbeiroAlteraPreco Boolean @default(false) @map("TQE_BAR_BARBEIRO_ALTERA_PRECO")
  criadoEm    DateTime @default(now()) @map("TQE_BAR_CRIADO_EM") @db.Timestamptz

  membros        MembroBarbearia[]
  servicos       Servico[]
  agendamentos   Agendamento[]
  itens          AgendamentoItem[]
  bloqueios      BloqueioAgenda[]
  jornadas       JornadaTrabalho[]
  barbeirosServ  BarbeiroServico[]
  tema           TemaTenant?
  preferencias   NotificacaoPreferencia[]
  horarios       HorarioFuncionamento[]
  convites       ConviteBarbearia[]
  clienteNotas   ClienteNota[]
  contatos       Contato[]
  pontosFidelidade PontoFidelidade[]
  apiKeys        ApiKey[]

  @@map("TQE_BARBEARIA")
}

/// Contato operacional: walk-in ou cliente cadastrado pelo barbeiro sem conta no app.
/// Não tem e-mail nem senha — nunca faz login. Separado de TQE_USUARIO para não
/// poluir a tabela de autenticação com registros sintéticos.
model Contato {
  codigo    Int      @id @default(autoincrement()) @map("TQE_CNT_CODIGO")
  barCodigo Int      @map("TQE_CNT_BAR_CODIGO")
  nome      String   @map("TQE_CNT_NOME")      @db.VarChar(100)
  telefone  String?  @map("TQE_CNT_TELEFONE")  @db.VarChar(20)
  criadoEm  DateTime @default(now()) @map("TQE_CNT_CRIADO_EM") @db.Timestamptz

  barbearia    Barbearia     @relation(fields: [barCodigo], references: [codigo])
  agendamentos Agendamento[] @relation("AgendamentosContato")

  @@map("TQE_CONTATO")
}

model MembroBarbearia {
  codigo    Int      @id @default(autoincrement()) @map("TQE_MBR_CODIGO")
  barCodigo Int      @map("TQE_MBR_BAR_CODIGO")
  usrCodigo Int      @map("TQE_MBR_USR_CODIGO")
  perfil    String   @map("TQE_MBR_PERFIL") @db.VarChar(20) // dono | gerente | barbeiro | recepcionista | cliente
  criadoEm  DateTime @default(now()) @map("TQE_MBR_CRIADO_EM") @db.Timestamptz

  barbearia Barbearia @relation(fields: [barCodigo], references: [codigo])
  usuario   Usuario   @relation(fields: [usrCodigo], references: [codigo])

  @@unique([barCodigo, usrCodigo])
  @@map("TQE_MEMBRO_BARBEARIA")
}

/// Nota privada de um barbeiro sobre um cliente (ex.: "máquina 2 nas laterais").
/// Visível apenas para o barbeiro autor, escopada por barbearia. Uma nota por
/// (barbearia, barbeiro, cliente) — atualizada via upsert.
model ClienteNota {
  codigo       Int      @id @default(autoincrement()) @map("TQE_CLN_CODIGO")
  barCodigo    Int      @map("TQE_CLN_BAR_CODIGO")
  barbeiroId   Int      @map("TQE_CLN_BARBEIRO_ID")
  clienteId    Int      @map("TQE_CLN_CLIENTE_ID")
  conteudo     String   @map("TQE_CLN_CONTEUDO") @db.Text
  criadoEm     DateTime @default(now()) @map("TQE_CLN_CRIADO_EM") @db.Timestamptz
  atualizadoEm DateTime @updatedAt @map("TQE_CLN_ATUALIZADO_EM") @db.Timestamptz

  barbearia Barbearia @relation(fields: [barCodigo], references: [codigo])
  barbeiro  Usuario   @relation("NotaBarbeiro", fields: [barbeiroId], references: [codigo])
  cliente   Usuario   @relation("NotaCliente", fields: [clienteId], references: [codigo])

  @@unique([barCodigo, barbeiroId, clienteId])
  @@map("TQE_CLIENTE_NOTA")
}

model TemaTenant {
  codigo      Int      @id @default(autoincrement()) @map("TQE_TEM_CODIGO")
  barCodigo   Int      @unique @map("TQE_TEM_BAR_CODIGO")
  corPrimaria String?  @map("TQE_TEM_COR_PRIMARIA") @db.VarChar(7)
  corFundo    String?  @map("TQE_TEM_COR_FUNDO") @db.VarChar(7)
  logoUrl     String?  @map("TQE_TEM_LOGO_URL")
  subdominio  String?  @map("TQE_TEM_SUBDOMINIO") @db.VarChar(60)

  barbearia   Barbearia @relation(fields: [barCodigo], references: [codigo])

  @@map("TQE_TEMA_TENANT")
}

model PlanoLimite {
  codigo           Int      @id @default(autoincrement()) @map("TQE_PLI_CODIGO")
  // Valores: free | basic | pro
  plano            String   @unique @map("TQE_PLI_PLANO") @db.VarChar(20)
  preco            Decimal  @default(0) @map("TQE_PLI_PRECO") @db.Decimal(10, 2)
  maxBarbeiros     Int?     @map("TQE_PLI_MAX_BARBEIROS")
  maxAgdMes        Int?     @map("TQE_PLI_MAX_AGD_MES")
  whiteLabel       Boolean  @default(false) @map("TQE_PLI_WHITE_LABEL")
  apiPublica       Boolean  @default(false) @map("TQE_PLI_API_PUBLICA")
  relatoriosAdv    Boolean  @default(false) @map("TQE_PLI_RELATORIOS_ADV")

  @@map("TQE_PLANO_LIMITE")
}

// ==========================================
// 3. AGENDA E SERVIÇOS (RLS APLICADO AQUI)
// ==========================================

model Servico {
  codigo     Int      @id @default(autoincrement()) @map("TQE_SRV_CODIGO")
  barCodigo  Int      @map("TQE_SRV_BAR_CODIGO")
  nome       String   @map("TQE_SRV_NOME") @db.VarChar(100)
  precoBase  Decimal? @map("TQE_SRV_PRECO_BASE") @db.Decimal(10, 2)
  duracaoBase Int?    @map("TQE_SRV_DURACAO_BASE") // em minutos
  ativo      Boolean  @default(true) @map("TQE_SRV_ATIVO")
  // Quando preenchido, é um serviço EXCLUSIVO daquele barbeiro (não da barbearia).
  exclusivoBarbeiroId Int? @map("TQE_SRV_EXCLUSIVO_BARBEIRO_ID")

  barbearia  Barbearia         @relation(fields: [barCodigo], references: [codigo])
  exclusivoBarbeiro Usuario?    @relation("ServicoExclusivo", fields: [exclusivoBarbeiroId], references: [codigo])
  itens      AgendamentoItem[]
  barbeiros  BarbeiroServico[]

  @@unique([nome, barCodigo])
  @@map("TQE_SERVICO")
}

model BarbeiroServico {
  codigo        Int      @id @default(autoincrement()) @map("TQE_BSV_CODIGO")
  barCodigo     Int      @map("TQE_BSV_BAR_CODIGO")
  barbeiroId    Int      @map("TQE_BSV_BARBEIRO_ID")
  srvCodigo     Int      @map("TQE_BSV_SRV_CODIGO")
  duracaoMin    Int      @map("TQE_BSV_DURACAO_MIN")
  precoProprio  Decimal? @map("TQE_BSV_PRECO_PROPRIO") @db.Decimal(10, 2)
  // false = o barbeiro NÃO realiza esse serviço (continua na lista, desativado)
  ativo         Boolean  @default(true) @map("TQE_BSV_ATIVO")

  barbearia Barbearia @relation(fields: [barCodigo], references: [codigo])
  barbeiro  Usuario   @relation(fields: [barbeiroId], references: [codigo])
  servico   Servico   @relation(fields: [srvCodigo], references: [codigo])

  @@unique([barbeiroId, srvCodigo])
  @@map("TQE_BARBEIRO_SERVICO")
}

model Agendamento {
  codigo      Int      @id @default(autoincrement()) @map("TQE_AGD_CODIGO")
  barCodigo   Int      @map("TQE_AGD_BAR_CODIGO")
  barbeiroId  Int      @map("TQE_AGD_BARBEIRO_ID")
  // Exatamente um de clienteId / contatoId deve estar preenchido.
  // A constraint XOR é SQL pura (ver migration add_tqe_contato) — o Prisma
  // não valida isso; a camada de serviço garante a invariante.
  clienteId   Int?     @map("TQE_AGD_CLIENTE_ID") // usuário autenticável (TQE_USUARIO)
  contatoId   Int?     @map("TQE_AGD_CONTATO_ID") // contato operacional (TQE_CONTATO)
  inicio      DateTime @map("TQE_AGD_INICIO") @db.Timestamptz
  fim         DateTime @map("TQE_AGD_FIM") @db.Timestamptz
  status      String   @default("pendente") @map("TQE_AGD_STATUS") @db.VarChar(20) // pendente | confirmado | cancelado | no_show | concluido | em_andamento
  tipo        String   @default("AGENDADO") @map("TQE_AGD_TIPO") @db.VarChar(20) // AGENDADO | WALK_IN | ENCAIXE
  observacao         String?  @map("TQE_AGD_OBSERVACAO") @db.Text
  criadoEm           DateTime @default(now()) @map("TQE_AGD_CRIADO_EM") @db.Timestamptz
  lembrete24hEnviado Boolean  @default(false) @map("TQE_AGD_LEMBRETE_24H")
  lembrete2hEnviado  Boolean  @default(false) @map("TQE_AGD_LEMBRETE_2H")

  barbearia  Barbearia              @relation(fields: [barCodigo], references: [codigo])
  barbeiro   Usuario                @relation("AgendamentosBarbeiro", fields: [barbeiroId], references: [codigo])
  cliente    Usuario?               @relation("AgendamentosCliente", fields: [clienteId], references: [codigo])
  contato    Contato?               @relation("AgendamentosContato", fields: [contatoId], references: [codigo])
  itens      AgendamentoItem[]
  avaliacao  AvaliacaoAgendamento?
  pontosFidelidade PontoFidelidade[]

  // partial unique index gerenciado via migration SQL (exclui WALK_IN)
  // ver migration 20260516_walkin_partial_unique
  @@map("TQE_AGENDAMENTO")
}

model AvaliacaoAgendamento {
  codigo            Int         @id @default(autoincrement()) @map("TQE_AVL_CODIGO")
  agendamentoCodigo Int         @unique @map("TQE_AVL_AGD_CODIGO")
  nota              Int         @map("TQE_AVL_NOTA") @db.SmallInt
  comentario        String?     @map("TQE_AVL_COMENTARIO") @db.Text
  criadoEm          DateTime    @default(now()) @map("TQE_AVL_CRIADO_EM") @db.Timestamptz

  agendamento       Agendamento @relation(fields: [agendamentoCodigo], references: [codigo])

  @@map("TQE_AVALIACAO_AGENDAMENTO")
}

model AgendamentoItem {
  codigo      Int      @id @default(autoincrement()) @map("TQE_AGI_CODIGO")
  barCodigo   Int      @map("TQE_AGI_BAR_CODIGO")
  agdCodigo   Int      @map("TQE_AGI_AGD_CODIGO")
  srvCodigo   Int      @map("TQE_AGI_SRV_CODIGO")
  duracaoMin  Int      @map("TQE_AGI_DURACAO_MIN")
  preco       Decimal  @map("TQE_AGI_PRECO") @db.Decimal(10, 2)
  ordem       Int      @default(1) @map("TQE_AGI_ORDEM") @db.SmallInt

  barbearia   Barbearia   @relation(fields: [barCodigo], references: [codigo])
  agendamento Agendamento @relation(fields: [agdCodigo], references: [codigo])
  servico     Servico     @relation(fields: [srvCodigo], references: [codigo])

  @@unique([agdCodigo, srvCodigo])
  @@map("TQE_AGENDAMENTO_ITEM")
}

model BloqueioAgenda {
  codigo      Int      @id @default(autoincrement()) @map("TQE_BLA_CODIGO")
  barCodigo   Int      @map("TQE_BLA_BAR_CODIGO")
  barbeiroId  Int      @map("TQE_BLA_BARBEIRO_ID")
  inicio      DateTime @map("TQE_BLA_INICIO") @db.Timestamptz
  fim         DateTime @map("TQE_BLA_FIM") @db.Timestamptz
  motivo      String?  @map("TQE_BLA_MOTIVO") @db.VarChar(100)
  recorrente  Boolean  @default(false) @map("TQE_BLA_RECORRENTE")
  criadoEm    DateTime @default(now()) @map("TQE_BLA_CRIADO_EM") @db.Timestamptz

  barbearia   Barbearia @relation(fields: [barCodigo], references: [codigo])
  barbeiro    Usuario   @relation(fields: [barbeiroId], references: [codigo])

  @@map("TQE_BLOQUEIO_AGENDA")
}

model JornadaTrabalho {
  codigo      Int      @id @default(autoincrement()) @map("TQE_JOR_CODIGO")
  barCodigo   Int      @map("TQE_JOR_BAR_CODIGO")
  barbeiroId  Int      @map("TQE_JOR_BARBEIRO_ID")
  diaSemana   Int      @map("TQE_JOR_DIA_SEMANA") @db.SmallInt // 0=Dom, 1=Seg... 6=Sab
  inicio      String   @map("TQE_JOR_INICIO") // "09:00" em VarChar porque Db.Time não mapeia bem para DateTime no Node sem timezone issues
  fim         String   @map("TQE_JOR_FIM")
  almocoIni   String?  @map("TQE_JOR_ALMOCO_INI")
  almocoFim   String?  @map("TQE_JOR_ALMOCO_FIM")
  ativo       Boolean  @default(true) @map("TQE_JOR_ATIVO")

  barbearia   Barbearia @relation(fields: [barCodigo], references: [codigo])
  barbeiro    Usuario   @relation(fields: [barbeiroId], references: [codigo])

  @@map("TQE_JORNADA_TRABALHO")
}

model ApiKey {
  codigo      Int       @id @default(autoincrement()) @map("TQE_AK_CODIGO")
  barCodigo   Int       @map("TQE_AK_BAR_CODIGO")
  nome        String    @map("TQE_AK_NOME") @db.VarChar(100)
  keyHash     String    @unique @map("TQE_AK_KEY_HASH") @db.VarChar(255)
  keyPrefix   String    @map("TQE_AK_KEY_PREFIX") @db.VarChar(10)
  ativo       Boolean   @default(true) @map("TQE_AK_ATIVO")
  criadoEm   DateTime  @default(now()) @map("TQE_AK_CRIADO_EM") @db.Timestamptz
  ultimoUsoEm DateTime? @map("TQE_AK_ULTIMO_USO_EM") @db.Timestamptz

  barbearia   Barbearia @relation(fields: [barCodigo], references: [codigo])

  @@map("TQE_API_KEY")
}

model NotificacaoPreferencia {
  codigo      Int      @id @default(autoincrement()) @map("TQE_NPR_CODIGO")
  barCodigo   Int      @map("TQE_NPR_BAR_CODIGO")
  usrCodigo   Int      @map("TQE_NPR_USR_CODIGO")
  canal       String   @map("TQE_NPR_CANAL") @db.VarChar(20) // push | whatsapp | sms | email
  ativo       Boolean  @default(true) @map("TQE_NPR_ATIVO")

  barbearia   Barbearia @relation(fields: [barCodigo], references: [codigo])
  usuario     Usuario   @relation(fields: [usrCodigo], references: [codigo])

  @@map("TQE_NOTIFICACAO_PREFERENCIA")
}

model PushToken {
  codigo      Int      @id @default(autoincrement()) @map("TQE_PTK_CODIGO")
  usrCodigo   Int      @map("TQE_PTK_USR_CODIGO")
  token       String   @map("TQE_PTK_TOKEN") @db.VarChar(255)
  plataforma  String   @default("unknown") @map("TQE_PTK_PLATAFORMA") @db.VarChar(10) // ios | android | unknown
  criadoEm   DateTime @default(now()) @map("TQE_PTK_CRIADO_EM") @db.Timestamptz

  usuario    Usuario  @relation(fields: [usrCodigo], references: [codigo], onDelete: Cascade)

  @@unique([usrCodigo, token])
  @@map("TQE_PUSH_TOKEN")
}

model HorarioFuncionamento {
  codigo     Int      @id @default(autoincrement()) @map("TQE_HFN_CODIGO")
  barCodigo  Int      @map("TQE_HFN_BAR_CODIGO")
  diaSemana  Int      @map("TQE_HFN_DIA_SEMANA") @db.SmallInt // 0=Dom, 1=Seg … 6=Sab
  aberto     Boolean  @default(true) @map("TQE_HFN_ABERTO")
  abertura   String   @map("TQE_HFN_ABERTURA") @db.VarChar(5)   // "09:00"
  fechamento String   @map("TQE_HFN_FECHAMENTO") @db.VarChar(5) // "18:00"

  barbearia  Barbearia @relation(fields: [barCodigo], references: [codigo], onDelete: Cascade)

  @@unique([barCodigo, diaSemana])
  @@map("TQE_HORARIO_FUNCIONAMENTO")
}

model ConviteBarbearia {
  codigo       Int       @id @default(autoincrement()) @map("TQE_CVT_CODIGO")
  token        String    @unique @default(cuid()) @map("TQE_CVT_TOKEN") @db.VarChar(36)
  barCodigo    Int       @map("TQE_CVT_BAR_CODIGO")
  email        String    @map("TQE_CVT_EMAIL") @db.VarChar(100)
  perfil       String    @default("barbeiro") @map("TQE_CVT_PERFIL") @db.VarChar(20)
  criadoEm    DateTime  @default(now()) @map("TQE_CVT_CRIADO_EM") @db.Timestamptz
  expiresAt    DateTime  @map("TQE_CVT_EXPIRES_AT") @db.Timestamptz
  usadoEm     DateTime? @map("TQE_CVT_USADO_EM") @db.Timestamptz

  barbearia    Barbearia @relation(fields: [barCodigo], references: [codigo])

  @@map("TQE_CONVITE_BARBEARIA")
}

// ==========================================
// 5. FIDELIDADE
// ==========================================

model PontoFidelidade {
  codigo            Int       @id @default(autoincrement()) @map("TQE_PF_CODIGO")
  barCodigo         Int       @map("TQE_PF_BAR_CODIGO")
  clienteCodigo     Int       @map("TQE_PF_CLI_CODIGO")
  pontos            Int       @map("TQE_PF_PONTOS")
  tipo              String    @map("TQE_PF_TIPO") @db.VarChar(20) // 'ganho' | 'resgate'
  agendamentoCodigo Int?      @map("TQE_PF_AGD_CODIGO")
  criadoEm          DateTime  @default(now()) @map("TQE_PF_CRIADO_EM") @db.Timestamptz

  barbearia   Barbearia    @relation(fields: [barCodigo], references: [codigo])
