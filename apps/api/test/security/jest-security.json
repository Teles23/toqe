{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../../",
  "testRegex": "test/security/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "globalSetup": "<rootDir>/test/integration/setup.ts",
  "globalTeardown": "<rootDir>/test/integration/teardown.ts",
  "testTimeout": 60000
}
