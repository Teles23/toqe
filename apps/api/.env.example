# ==========================================
# API (NestJS)
# Ambiente de Desenvolvimento Local
# ==========================================
PORT=3000
NODE_ENV=development

# Nível de log do Pino (trace | debug | info | warn | error | fatal).
# DEV: "debug" para mais detalhe; PROD: "info" ou "warn".
# opcional (padrão: info)
LOG_LEVEL=info

# URL pública da API — usada para construir URLs absolutas de arquivos estáticos (ex: logo da barbearia).
# DEV:  http://localhost:3000  (se browser e API no mesmo host)
#       http://SEU_IP:3000     (ex: http://192.168.100.55:3000 em WSL2 acessado do Windows)
# PROD: https://api.toqe.com.br (ou o domínio real sem trailing slash)
API_BASE_URL=http://localhost:3000

# Conexão com o banco de dados (Acessando o Docker pelo localhost na porta 5432)
DATABASE_URL="postgresql://toqe_app:senha_forte@localhost:5432/toqe?schema=public"

# Redis para filas (BullMQ) e cache
# ATENÇÃO: em produção com Docker Compose, usar o nome do serviço ("redis"),
# não "localhost" — dentro do container, localhost é o próprio container da API.
# DEV (API rodando direto no host): localhost
# PROD (Docker Compose):            redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=senha_forte

# Chaves de Autenticação JWT
JWT_SECRET=super_secret_jwt_key_aqui
JWT_REFRESH_SECRET=super_secret_refresh_key_aqui

# HMAC secret para hash de API keys — impede geração de hashes válidos mesmo com acesso ao banco
API_KEY_HMAC_SECRET=seu-secret-para-hmac-de-api-keys

# Notificações — Resend (https://resend.com)
# Obtenha sua chave em https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Remetente dos e-mails transacionais.
# DEV:  "onboarding@resend.dev" funciona sem verificar domínio (padrão se omitido)
# PROD: "Toqe <noreply@toqe.com.br>" — requer domínio verificado no painel do Resend
EMAIL_FROM=onboarding@resend.dev

# URL base do frontend — usada para montar links em e-mails (reset de senha,
# convite de barbeiro). O link de convite fica `${FRONTEND_URL}/convite?token=...`.
# Fallback no código: http://localhost:4001
FRONTEND_URL=http://localhost:4001

# Domínio/URL pública de agendamento — usado para gerar links compartilháveis.
# Use o host do Web, porque ele é o fallback quando o app mobile não estiver
# instalado e também serve os arquivos de Universal/App Links.
# opcional (padrão: https://app.toqe-barber.com.br)
PUBLIC_BOOKING_DOMAIN=https://app.toqe-barber.com.br

# Google OAuth (Web Client ID) — usado para validar ID tokens no endpoint /auth/google
# Deve ser o MESMO valor que está configurado no mobile (apps/mobile/.env GOOGLE_WEB_CLIENT_ID)
# Obtido em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Origens permitidas pelo CORS — separadas por vírgula, sem espaços
# Obrigatório em produção (NODE_ENV=production). A API rejeita o boot se não estiver definido.
# Exemplo: https://app.toqe.com.br,https://admin.toqe.com.br
CORS_ORIGINS=https://app.toqe.com.br

# E-mail do super admin (fundador da plataforma).
# Na inicialização da API, o campo superAdmin=true é setado automaticamente para este usuário.
# Deixe em branco em ambientes de teste/staging que não precisam de super admin.
SUPER_ADMIN_EMAIL=

# Asaas (gateway de pagamento) — https://www.asaas.com
ASAAS_API_KEY=sua-api-key-do-asaas
ASAAS_WEBHOOK_TOKEN=token-configurado-no-painel-asaas
# DEV:  https://sandbox.asaas.com/api/v3 (padrão no código se omitido)
# PROD: https://www.asaas.com/api/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
