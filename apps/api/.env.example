# ==========================================
# API (NestJS)
# Ambiente de Desenvolvimento Local
# ==========================================
PORT=3000
NODE_ENV=development

# Conexão com o banco de dados (Acessando o Docker pelo localhost na porta 5432)
DATABASE_URL="postgresql://toqe_app:senha_forte@localhost:5432/toqe?schema=public"

# Redis para filas (BullMQ) e cache (Acessando o Docker pelo localhost)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=senha_forte

# Chaves de Autenticação JWT
JWT_SECRET=super_secret_jwt_key_aqui
JWT_REFRESH_SECRET=super_secret_refresh_key_aqui

# Notificações — Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# URL base do frontend — usada para montar links em e-mails (reset de senha,
# convite de barbeiro). O link de convite fica `${FRONTEND_URL}/convite?token=...`.
# Fallback no código: http://localhost:4001
FRONTEND_URL=http://localhost:4001

# Google OAuth (Web Client ID) — usado para validar ID tokens no endpoint /auth/google
# Deve ser o MESMO valor que está configurado no mobile (apps/mobile/.env GOOGLE_WEB_CLIENT_ID)
# Obtido em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=1095847529893-b71gjl8nqpjl5vo0ppd5c5iljfof684m.apps.googleusercontent.com

# E-mail do super admin (fundador da plataforma).
# Na inicialização da API, o campo superAdmin=true é setado automaticamente para este usuário.
# Deixe em branco em ambientes de teste/staging que não precisam de super admin.
SUPER_ADMIN_EMAIL=
