# ==========================================
# MOBILE (Expo / React Native)
# Ambiente de Desenvolvimento Local
# ==========================================
#
# Copie este arquivo para `.env.local` (gitignored) e ajuste os valores.
# Variáveis com prefixo EXPO_PUBLIC_ são expostas ao bundle do app (client-side).
# Variáveis sem prefixo só existem em tempo de build/metro — não chegam ao runtime.
#
# Fluxo de resolução da URL da API:
#   expo start (dev)       → usa EXPO_PUBLIC_API_URL deste arquivo
#   eas build preview/prod → usa EXPO_PUBLIC_API_URL definido em eas.json
#   fallback (nenhuma)     → https://api.toqe-barber.com.br/api/v1 (produção)
#
# Para encontrar seu IP LAN: ipconfig (Windows) / ip addr (Linux)

# ── URL da API ─────────────────────────────────────────────────────────────────

# URL base da API NestJS que o app vai chamar em runtime.
# Escolha conforme onde o app está rodando:
#   Celular físico (mesma Wi-Fi):  http://<IP_LAN_DA_MAQUINA>:3000/api/v1
#   Emulador Android:              http://10.0.2.2:3000/api/v1
#   Simulador iOS:                 http://localhost:3000/api/v1
# OBRIGATÓRIO para dev local
EXPO_PUBLIC_API_URL=http://192.168.0.10:3000/api/v1

# Domínio HTTPS que pode abrir o app por Universal Links/App Links.
# Precisa bater com os arquivos /.well-known servidos pelo Web.
# Build preview/prod usa app.toqe-barber.com.br via eas.json.
EXPO_PUBLIC_APP_LINK_DOMAIN=app.toqe-barber.com.br

# ── Rede local (dev) ───────────────────────────────────────────────────────────

# IP LAN da máquina de desenvolvimento.
# Usado pelo scripts/start-dev.js para configurar o Metro bundler corretamente
# em ambientes Windows/WSL2 com múltiplas interfaces de rede (Hyper-V, Docker, etc.).
# Se omitido, o script detecta automaticamente o IP da interface Wi-Fi.
# opcional
MOBILE_HOST_IP=192.168.0.10

# ── Firebase / Google Services ─────────────────────────────────────────────────

# Conteúdo JSON do google-services.json (base64 ou JSON inline).
# Usado em builds EAS CI/CD para evitar commitar o arquivo no repositório.
# Em dev local, o arquivo google-services.json já existe na raiz do app.
# Obtenha em: https://console.firebase.google.com → seu projeto → Configurações → google-services.json
# opcional (apenas builds EAS em CI)
GOOGLE_SERVICES_JSON=

# ── Ferramentas de desenvolvimento ────────────────────────────────────────────

# Desativa o expo-keep-awake durante testes automatizados (Jest/Maestro).
# Defina como "1" apenas em ambientes de CI onde a tela nunca precisa ficar ativa.
# opcional (padrão: não definido = keep-awake ativo)
TOQE_DISABLE_KEEP_AWAKE=
