{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@toqe/shared": ["packages/shared/src/index.ts"],
      "@toqe/validators": ["packages/validators/src/index.ts"],
      "@toqe/config": ["packages/config/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true
  }
}
