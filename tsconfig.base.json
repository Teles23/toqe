{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@toqe/shared": ["packages/shared/src/index.ts"],
      "@toqe/contracts": ["packages/contracts/src/index.ts"],
      "@toqe/contracts/schemas": ["packages/contracts/src/schemas/index.ts"],
      "@toqe/contracts/schemas/*": ["packages/contracts/src/schemas/*.ts"],
      "@toqe/contracts/types": ["packages/contracts/src/types/index.ts"],
      "@toqe/contracts/errors": ["packages/contracts/src/errors/index.ts"],
      "@toqe/config": ["packages/config/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true
  }
}
